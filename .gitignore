# Simulation outputs. `simulation_results/` above (line ~35) would ignore the
# whole dev/simulation_results tree; re-include the directory here so the
# summarised report artifacts + raw per-cell chunks are tracked ("go back"
# recoverability). Large raw bundles (reference datasets, eval RDS) stay
# ignored via the `*` child-exclude with no matching negation.
!dev/simulation_results/
dev/simulation_results/*
!dev/simulation_results/README.md
!dev/simulation_results/SIMULATION_REPORT.md
!dev/simulation_results/*.csv
!dev/simulation_results/recovery_simulation.rds
!dev/simulation_results/response_type_simulation.rds
!dev/simulation_results/figures/
!dev/simulation_results/logs/
!dev/simulation_results/response_type_chunks/
dev/benchmark_results/

# Local planning notes — not tracked, not built into the package
notes/

# VS Code / Quarto / RMarkdown HTML preview artefacts
# (the _files/ sidecars contain JS/CSS/fonts that we don't want tracked)
dev/*.html
dev/*_files/
*.html
*_files/
